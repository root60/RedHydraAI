# RedHydra OpenCore public configuration
# Safe to commit to GitHub. No private tokens, no vendor secrets, no old vendor references.

VITE_APP_NAME=RedHydra OpenCore
VITE_PUBLIC_BUILD=github-pages
VITE_GITHUB_PAGES_BASE=/RedHydraOpenCore/

# Actual default model target. Run it behind a local/GPU OpenAI-compatible endpoint
# such as TabbyAPI, ExLlamaV2 OpenAI server, LM Studio, vLLM, or Ollama-compatible bridge.
VITE_REDHYDRA_BASE_MODEL=dphn/Dolphin-Llama3-8B-Instruct-exl2-6bpw
VITE_DEFAULT_PROVIDER=opencore-local
VITE_DEFAULT_BASE_URL=

# Public feature flags
VITE_CHAT_DEFAULT_MODE=chat
VITE_ENABLE_AGENT_MODE=true
VITE_ENABLE_THINKING_CONTROLS=true
VITE_ENABLE_USAGE_DASHBOARD=true
VITE_ENABLE_LIVE_USAGE_MONITOR=true
VITE_ENABLE_WEB_RESEARCH=true
VITE_ENABLE_FILE_ANALYZER=true
VITE_ENABLE_EXPORT=true

# Public browser-only research sources. These do not require private keys.
VITE_ENABLE_WIKIPEDIA_SEARCH=true
VITE_ENABLE_DUCKDUCKGO_INSTANT=true
VITE_ENABLE_CROSSREF_SEARCH=true
VITE_ENABLE_HN_SEARCH=true
