# Open-source-safe RedHydra backend config.
# No private key is required in this file.

APP_NAME=RedHydra OpenCore Python Backend
APP_VERSION=1.2.0

# Keep blank for demo/source-only mode.
# For real model answers, deploy an OpenAI-compatible server and set its base URL.
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=
DEFAULT_MODEL=dphn/Dolphin-Llama3-8B-Instruct-exl2-6bpw

# true = open-source demo mode. false = use UPSTREAM_BASE_URL for real model output.
DEMO_MODE=true

ALLOWED_ORIGINS=*
MAX_TOKENS=1200
REQUEST_TIMEOUT_SECONDS=180

# Research is enabled by default, but auto mode avoids slowing every small chat.
ENABLE_WEB_SEARCH=true
ENABLE_DEEP_RESEARCH=true
WEB_SEARCH_MODE=auto
WEB_SEARCH_MAX_RESULTS=5
DEEP_RESEARCH_MAX_RESULTS=8
DEEP_RESEARCH_MAX_PAGES=4
WEB_CONTEXT_CHAR_LIMIT=12000
SEARCH_TIMEOUT_SECONDS=12
PAGE_FETCH_TIMEOUT_SECONDS=10
RESEARCH_CACHE_TTL_SECONDS=900
